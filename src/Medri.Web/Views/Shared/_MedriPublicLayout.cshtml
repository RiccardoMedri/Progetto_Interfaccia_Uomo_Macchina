@{
    var title = ViewData["Title"] as string ?? "Agenzia Immobiliare";
    var bodyClass = ViewData["BodyClass"] as string ?? "medri-public-body";
    var renderMedriHeader = ViewData["RenderMedriHeader"] as bool? ?? true;
    var renderMedriFooter = ViewData["RenderMedriFooter"] as bool? ?? true;
    var shellClass = ViewData["MedriShellClass"] as string ?? "medri-public-shell";
    
    
    var pageBundle = ViewData["PageBundle"] as string;
}
<!doctype html>
<html lang="it">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="stylesheet" href="/css/medri-base.css" />
    @if (pageBundle != null)
    {
        <link rel="stylesheet" href="/css/medri-@(pageBundle).css" />
    }
    @RenderSection("styles", required: false)
</head>
<body class="@bodyClass" data-authenticated="@(User.Identity?.IsAuthenticated == true ? "true" : "false")">
    <a class="skip-link" href="#contenuto">Salta al contenuto</a>
    <div class="@shellClass">
        @if (renderMedriHeader)
        {
            @await Component.InvokeAsync("MedriHeader")
        }
        @RenderBody()
        @if (renderMedriFooter)
        {
            <partial name="~/Features/Views/Shared/_MedriFooter.cshtml" />
        }
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/public-property-actions.js" defer></script>
    @RenderSection("scripts", required: false)
</body>
</html>
