{
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass --no-source-map --style=compressed --quiet-deps --silence-deprecation=import --load-path=node_modules ClientAssets/scss:wwwroot/css",
    "build:js": "esbuild ClientAssets/ts/admin-featured-slots.ts ClientAssets/ts/admin-property-media.ts ClientAssets/ts/home-search.ts ClientAssets/ts/public-property-actions.ts ClientAssets/ts/search-map.ts --bundle --minify --target=es2019 --outdir=wwwroot/js",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "bootstrap": "5.3.3",
    "esbuild": "0.28.1",
    "sass": "1.93.2",
    "typescript": "6.0.3"
  }
}
