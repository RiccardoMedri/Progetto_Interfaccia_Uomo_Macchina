@inject Microsoft.Extensions.Options.IOptions<Medri.Web.Infrastructure.AgencyContactOptions> AgencyContactOptions
@{
    var agencyContact = AgencyContactOptions.Value;
}

<footer class="site-footer" aria-label="Informazioni agenzia">
    <div class="footer-info">
        <div class="footer-brand">
            <strong>AGENZIA</strong>
            <p>Servizi immobiliari a Cesena dal 1974.</p>
        </div>
        <div class="footer-contact">
            <span>@agencyContact.AddressLabel</span>
            <a href="@agencyContact.PhoneHref">@agencyContact.PhoneLabel</a>
            <a href="@agencyContact.EmailHref">@agencyContact.EmailLabel</a>
        </div>
        <nav class="footer-links" aria-label="Collegamenti footer">
            <a asp-controller="Search" asp-action="Index">Immobili</a>
            <a asp-controller="LeadIntake" asp-action="Sell">Vendere</a>
            <a asp-controller="LeadIntake" asp-action="RentOut">Affittare</a>
        </nav>
    </div>
</footer>
