@model Medri.Web.Features.LeadIntake.LeadFunnelTimePreferencesViewModel

<section class="@Model.SectionClass">
    <h2>@Model.Heading</h2>
    <input id="@Model.SlotFieldName" name="@Model.SlotFieldName" type="hidden" value="@Model.NormalizedSelectedTimeSlot" />
    <div class="row row-cols-2 row-cols-md-4 g-3">
        <div class="col">
            <button class="time-choice-button h-100 w-100 @(Model.NormalizedSelectedTimeSlot == "Mattina" ? "is-selected" : null)" type="button" data-time-choice="Mattina">
                <strong>Mattina</strong>
                <span>9-12</span>
            </button>
        </div>
        <div class="col">
            <button class="time-choice-button h-100 w-100 @(Model.NormalizedSelectedTimeSlot == "Pomeriggio" ? "is-selected" : null)" type="button" data-time-choice="Pomeriggio">
                <strong>Pomeriggio</strong>
                <span>14-17</span>
            </button>
        </div>
        <div class="col">
            <button class="time-choice-button h-100 w-100 @(Model.NormalizedSelectedTimeSlot == "Sera" ? "is-selected" : null)" type="button" data-time-choice="Sera">
                <strong>Sera</strong>
                <span>17-19</span>
            </button>
        </div>
        <div class="col">
            <button class="time-choice-button h-100 w-100 @(Model.IsCustomTime ? "is-selected" : null)" type="button" data-time-choice="Altro orario">
                <strong>Altro orario</strong>
                <span>Scegli giorno e ora</span>
            </button>
        </div>
    </div>
    <div class="custom-time-panel row g-3 @(Model.IsCustomTime ? null : "is-collapsed")" aria-label="Scelta giorno e orario specifico" data-custom-time>
        <div class="col-12 col-md-6">
            <label>
                <span class="form-label">Giorno</span>
                <input class="form-control" id="@Model.DayFieldName" name="@Model.DayFieldName" type="date" value="@Model.PreferredDay" />
            </label>
        </div>
        <div class="col-12 col-md-6">
            <label>
                <span class="form-label">Ora</span>
                <input class="form-control" id="@Model.TimeFieldName" name="@Model.TimeFieldName" type="time" value="@Model.PreferredTime" />
            </label>
        </div>
    </div>
    <span class="text-danger field-validation-valid" data-valmsg-for="@Model.SlotFieldName" data-valmsg-replace="true"></span>
</section>
