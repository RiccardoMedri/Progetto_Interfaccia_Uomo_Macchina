{
  "compileOnSave": false,
  "compilerOptions": {
    "noEmit": true,
    "noImplicitAny": false,
    "target": "es2019",
    "lib": [ "dom", "es2019" ],
    "ignoreDeprecations": "6.0",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true
  },
  "include": [
    "ClientAssets/ts/**/*.ts"
  ],
  "exclude": [
    "bin",
    "obj",
    "node_modules"
  ]
}
