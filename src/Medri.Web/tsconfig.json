{
  "compileOnSave": false,
  "compilerOptions": {
    "noEmitOnError": true,
    "noImplicitAny": false,
    "removeComments": true,
    "sourceMap": false,
    "target": "es5",
    "lib": [ "dom", "es2019" ],
    "ignoreDeprecations": "6.0",

    "skipLibCheck": true
  },
  "include": [
    "wwwroot/js/**/*.ts"
  ],
  "exclude": [
    "bin",
    "obj",
    "node_modules"
  ]
}
